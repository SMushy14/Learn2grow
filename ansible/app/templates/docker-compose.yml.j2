version: "3.8"

services:
  backend:
    image: "{{ backend_image }}"
    container_name: backend
    restart: always
    ports:
      - "5000:5000"
    environment:
      - NODE_ENV=production

  frontend:
    image: "{{ frontend_image }}"
    container_name: frontend
    restart: always
    ports:
      - "3000:3000"